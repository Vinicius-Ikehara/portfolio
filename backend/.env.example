# Arquivo de exemplo para variáveis de ambiente
DATABASE_URL=sqlite:///./portfolio.db
# Para PostgreSQL use: postgresql://user:password@localhost/portfolio

# Supabase - Last.fm Analytics
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-aqui

# Supabase - Pokédex (Vector Store + Chat Memory)
SUPABASE_POKEDEX_URL=https://seu-projeto-pokedex.supabase.co
SUPABASE_POKEDEX_KEY=sua-chave-pokedex-aqui

# OpenAI API (para Pokédex RAG)
OPENAI_API_KEY=sk-sua-chave-openai-aqui
OPENAI_MODEL=gpt-5.2

# Langfuse (opcional - observabilidade LLM)
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=pk-lf-sua-chave-aqui
# LANGFUSE_SECRET_KEY=sk-lf-sua-chave-aqui
